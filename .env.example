# Registry for Docker base image (optional)
REGISTRY=docker.io

# Frontend static files path
FRONTEND_PATH=frontend

# Printer IPP URL (required)
PRINTER_IPP_URL=ipp://your-printer-address:631/printers/your-printer-name

# Printer display name (optional)
PRINTER_NAME=your-printer-name

# API access token (required)
ACCESS_TOKEN=your-secret-access-token

# Maximum upload size in MB (optional, default: 50)
MAX_UPLOAD_MB=50

# Rate limit per IP (optional, default: 5/minute)
RATE_LIMIT_PER_IP=5/minute

# Logging level (optional, default: INFO)
LOG_LEVEL=INFO

# IPP default paper size (optional, default: iso_a4_210x297mm)
IPP_DEFAULT_MEDIA=iso_a4_210x297mm

# IPP default print quality (optional, default: normal)
IPP_DEFAULT_QUALITY=normal

# IPP default print orientation (optional, default: portrait)
IPP_DEFAULT_ORIENTATION=portrait

# Username for print jobs (optional, default: fastapi)
IPP_USER_NAME=fastapi
